# Force LF on files that must run on Linux containers and CI.
* text=auto eol=lf

# Shell, dockerfiles, compose, configs: always LF
*.sh        text eol=lf
Dockerfile  text eol=lf
*.Dockerfile text eol=lf
Makefile    text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf
*.toml      text eol=lf
*.sql       text eol=lf
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf

# Caddy / nginx
Caddyfile        text eol=lf
Caddyfile.example text eol=lf

# Binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.pfx   binary
*.p12   binary
