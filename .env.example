# =============================================================================
# M365 Enterprise Control Center — environment template
# Copy to `.env` and fill in real values. Never commit the real `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
ENVIRONMENT=development            # development | staging | production
APP_NAME="M365 Enterprise Control Center"
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000
LOG_LEVEL=info                     # debug | info | warning | error
LOG_FORMAT=json                    # json | console

# -----------------------------------------------------------------------------
# Auth — production uses Entra OIDC only.
# Mock auth is for local dev only and refuses to start when ENVIRONMENT=production.
# -----------------------------------------------------------------------------
AUTH_MODE=mock                     # mock | entra
DEV_SESSION_SECRET=change-me-to-a-32-byte-random-value
SESSION_COOKIE_NAME=tg365_session
SESSION_IDLE_TIMEOUT_MINUTES=60
SESSION_ABSOLUTE_TIMEOUT_HOURS=12
CSRF_COOKIE_NAME=tg365_csrf

# Entra OIDC (fill in after creating the app registration — see docs/microsoft-graph/app-registration.md)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8000/auth/callback
ENTRA_AUTHORITY=https://login.microsoftonline.com

# -----------------------------------------------------------------------------
# Microsoft Graph (used by collectors in Phase 3+)
# -----------------------------------------------------------------------------
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_BETA_BASE_URL=https://graph.microsoft.com/beta
GRAPH_DEFAULT_PAGE_SIZE=100
GRAPH_MAX_RETRIES=8
GRAPH_BACKOFF_BASE_SECONDS=1
GRAPH_BACKOFF_CAP_SECONDS=60
GRAPH_PER_TENANT_CONCURRENCY=4

# Token cache encryption (used by API and worker; must match across services).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TOKEN_CACHE_MASTER_KEY=change-me-to-a-strong-random-key

# -----------------------------------------------------------------------------
# Database — Postgres
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tg365
POSTGRES_USER=tg365
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://tg365:change-me@postgres:5432/tg365

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# OpenSearch
# -----------------------------------------------------------------------------
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_PREFIX=tg365

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_REGION=us-east-1
MINIO_ROOT_USER=tg365admin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET_EXPORTS=tg365-exports
MINIO_BUCKET_EVIDENCE=tg365-evidence
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Mail (Mailhog locally; real SMTP in prod)
# -----------------------------------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
MAIL_FROM_ADDRESS="M365 Control Center <noreply@tg365.local>"

# -----------------------------------------------------------------------------
# Web (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="M365 Enterprise Control Center"

# -----------------------------------------------------------------------------
# Feature flags — destructive features OFF by default
# -----------------------------------------------------------------------------
FEATURE_REMEDIATION_ENABLED=false
FEATURE_CONTENT_SEARCH_ENABLED=false
FEATURE_DEFENDER_HUNTING_ENABLED=false
FEATURE_PURVIEW_AUDIT_ENABLED=false

# -----------------------------------------------------------------------------
# Telemetry (off locally)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=tg365-api
